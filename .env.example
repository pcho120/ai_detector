# Server-only secrets

# LLM Provider Configuration
# Select which LLM provider to use for generating rewrite suggestions.
# Options: openai, anthropic
# Default: openai
LLM_PROVIDER=openai

# LLM API Key
# Required for POST /api/suggestions on-demand rewrite generation.
# Without this key the endpoint returns a structured suggestion-unavailable response.
COACHING_LLM_API_KEY=your_llm_api_key_here

# Detection Provider Configuration
# Select which AI detection provider to use for content analysis.
# Options: sapling, winston, originality, gptzero
# Default: sapling
DETECTION_PROVIDER=sapling

# Detection API Keys
# Only the key for the selected DETECTION_PROVIDER is required.
SAPLING_API_KEY=your_sapling_api_key_here
# WINSTON_API_KEY=your_winston_api_key_here
# ORIGINALITY_API_KEY=your_originality_api_key_here
# GPTZERO_API_KEY=your_gptzero_api_key_here
